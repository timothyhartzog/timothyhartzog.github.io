{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "New Blog Post",
      "type": "shell",
      "command": "node",
      "args": ["scripts/new-blog-post.mjs", "${input:blogTitle}"],
      "group": "none",
      "presentation": {
        "reveal": "silent",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "New Analysis Article",
      "type": "shell",
      "command": "node",
      "args": ["scripts/new-analysis.mjs", "${input:analysisTitle}"],
      "group": "none",
      "presentation": {
        "reveal": "silent",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "New Marimo Notebook",
      "type": "shell",
      "command": "node",
      "args": ["scripts/new-notebook.mjs", "${input:notebookTitle}"],
      "group": "none",
      "presentation": {
        "reveal": "silent",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Open Marimo Editor",
      "type": "shell",
      "command": "marimo",
      "args": ["edit", "${input:notebookFile}"],
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Export All Notebooks",
      "type": "shell",
      "command": "node",
      "args": ["scripts/export-notebooks.mjs"],
      "group": "none",
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Dev Server",
      "type": "npm",
      "script": "dev",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "blogTitle",
      "description": "Blog post title",
      "type": "promptString",
      "default": "My New Post"
    },
    {
      "id": "analysisTitle",
      "description": "Analysis article title",
      "type": "promptString",
      "default": "My New Analysis"
    },
    {
      "id": "notebookTitle",
      "description": "Marimo notebook title",
      "type": "promptString",
      "default": "My Analysis"
    },
    {
      "id": "notebookFile",
      "description": "Path to notebook .py file",
      "type": "promptString",
      "default": "notebooks/sample-analysis.py"
    }
  ]
}
