{
  // ---------- Editor defaults for content writing ----------
  "editor.wordWrap": "on",
  "editor.minimap.enabled": false,
  "editor.lineNumbers": "on",
  "editor.fontSize": 14,
  "editor.tabSize": 2,

  // ---------- Markdown / MDX editing ----------
  "[markdown]": {
    "editor.quickSuggestions": false,
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 80,
    "editor.rulers": [80],
    "editor.defaultFormatter": "davidanson.vscode-markdownlint"
  },
  "[mdx]": {
    "editor.quickSuggestions": false,
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 80,
    "editor.rulers": [80]
  },

  // ---------- Spell Checker (cSpell) ----------
  "cSpell.enabled": true,
  "cSpell.language": "en",
  "cSpell.enableFiletypes": ["markdown", "mdx", "astro"],
  "cSpell.words": [
    "hartzog",
    "astro",
    "astrojs",
    "wasm",
    "recharts",
    "formspree",
    "plausible",
    "jsdelivr",
    "frontmatter",
    "codespace",
    "codespaces",
    "devcontainer",
    "webassembly",
    "gitlens",
    "markdownlint",
    "sitemap",
    "noindex"
  ],
  "cSpell.ignorePaths": [
    "node_modules",
    "dist",
    "package-lock.json",
    ".astro",
    "public/wasm"
  ],

  // ---------- Markdownlint ----------
  "markdownlint.config": {
    "MD013": false,
    "MD033": false,
    "MD041": false
  },

  // ---------- File associations ----------
  "files.associations": {
    "*.mdx": "mdx",
    "*.astro": "astro"
  },

  // ---------- Explorer: focus on content ----------
  "files.exclude": {
    "node_modules": true,
    "dist": true,
    ".astro": true
  },

  // ---------- Astro ----------
  "astro.enableServerPlugin": false
}
