---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('analysis');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} type="article" publishedDate={post.data.date} tags={post.data.tags}>
  <article class="prose">
    <header>
      <time datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1>{post.data.title}</h1>
      <p class="description">{post.data.description}</p>
      <div class="tags">
        {post.data.tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </header>
    <Content />
  </article>
  <a href="/analysis" class="back">&larr; Back to analysis</a>
</BaseLayout>

<style>
  article {
    margin: 0 auto;
  }

  header {
    margin-bottom: 2.5rem;
  }

  header time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  header h1 {
    font-size: 2.5rem;
    margin: 0.5rem 0;
  }

  .description {
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-size: 0.75rem;
    background: rgba(56, 189, 248, 0.1);
    color: var(--color-accent);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-weight: 500;
  }

  .back {
    display: inline-block;
    margin-top: 2.5rem;
    font-weight: 500;
  }
</style>
