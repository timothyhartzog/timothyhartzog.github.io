---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

// Scan the public/resources folder for files at build time
const resourcesDir = path.resolve('./public/resources');
let resources: { name: string; ext: string; size: string; href: string }[] = [];

if (fs.existsSync(resourcesDir)) {
  const files = fs.readdirSync(resourcesDir).filter((f) => !f.startsWith('.'));
  resources = files.map((file) => {
    const stat = fs.statSync(path.join(resourcesDir, file));
    const ext = path.extname(file).slice(1).toUpperCase();
    const sizeKB = stat.size / 1024;
    const size = sizeKB > 1024
      ? `${(sizeKB / 1024).toFixed(1)} MB`
      : `${Math.round(sizeKB)} KB`;
    return {
      name: path.basename(file, path.extname(file)).replace(/[-_]/g, ' '),
      ext,
      size,
      href: `/resources/${file}`,
    };
  });
}

const grouped = resources.reduce<Record<string, typeof resources>>((acc, r) => {
  const category = ['PDF', 'EPUB', 'MOBI'].includes(r.ext) ? 'Books & Documents' : 'Other Resources';
  (acc[category] ??= []).push(r);
  return acc;
}, {});
---

<BaseLayout title="Resources">
  <h1>Resources</h1>
  <p class="subtitle">
    Books, documents, and educational materials. Drop files into the
    <code>public/resources/</code> folder and they will appear here automatically
    on the next build.
  </p>

  {Object.keys(grouped).length > 0 ? (
    Object.entries(grouped).map(([category, items]) => (
      <section class="resource-section">
        <h2>{category}</h2>
        <div class="resource-grid">
          {items.map((r) => (
            <a href={r.href} class="resource-card" target="_blank" rel="noopener">
              <span class="ext-badge">{r.ext}</span>
              <h3>{r.name}</h3>
              <span class="size">{r.size}</span>
            </a>
          ))}
        </div>
      </section>
    ))
  ) : (
    <div class="empty-state">
      <p>No resources yet.</p>
      <p>
        Add PDFs, ebooks, or other files to <code>public/resources/</code> and
        they will be listed here after the next deploy.
      </p>
    </div>
  )}
</BaseLayout>

<style>
  h1 {
    font-size: 2.25rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
    font-size: 1.1rem;
    max-width: 65ch;
  }

  .subtitle code {
    font-size: 0.85em;
  }

  .resource-section {
    margin-bottom: 2.5rem;
  }

  .resource-section h2 {
    font-size: 1.35rem;
    margin-bottom: 1rem;
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
    transition: border-color 0.2s, transform 0.2s;
    color: var(--color-text);
  }

  .resource-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .ext-badge {
    align-self: flex-start;
    font-size: 0.7rem;
    font-weight: 700;
    background: rgba(56, 189, 248, 0.15);
    color: var(--color-accent);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .resource-card h3 {
    font-size: 1rem;
    text-transform: capitalize;
  }

  .size {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--color-text-muted);
  }

  .empty-state p {
    margin-bottom: 0.75rem;
  }
</style>
