---
/**
 * WasmLoader — Loads a Rust/WASM module and provides a container for rendering.
 *
 * Props:
 *   wasmUrl     — Path to the .wasm file (or .js glue from wasm-pack)
 *   containerId — ID for the rendering container div
 *   width       — Container width (default: 100%)
 *   height      — Container height (default: 400px)
 */

interface Props {
  wasmUrl: string;
  containerId?: string;
  width?: string;
  height?: string;
}

const {
  wasmUrl,
  containerId = 'wasm-container',
  width = '100%',
  height = '400px',
} = Astro.props;
---

<div class="wasm-wrapper" data-wasm-url={wasmUrl} data-container-id={containerId}>
  <div class="wasm-loading" id={`${containerId}-loading`}>
    <div class="spinner"></div>
    <span>Loading WASM module...</span>
  </div>
  <div class="wasm-error" id={`${containerId}-error`} style="display:none;">
    <span>Failed to load WASM module.</span>
  </div>
  <div
    class="wasm-container"
    id={containerId}
    style={`width: ${width}; height: ${height};`}
  ></div>
</div>

<script>
  document.querySelectorAll('.wasm-wrapper').forEach(async (wrapper) => {
    const url = wrapper.dataset.wasmUrl;
    const id = wrapper.dataset.containerId;
    const loading = wrapper.querySelector(`#${id}-loading`);
    const error = wrapper.querySelector(`#${id}-error`);
    const container = wrapper.querySelector(`#${id}`);

    if (!url || !container) return;

    try {
      // wasm-pack generates a JS glue file that exports an init function
      if (url.endsWith('.js')) {
        const mod = await import(/* @vite-ignore */ url);
        await mod.default();
        if (mod.render) mod.render(id);
      } else {
        // Raw .wasm — instantiate directly
        const response = await fetch(url);
        const bytes = await response.arrayBuffer();
        const { instance } = await WebAssembly.instantiate(bytes);
        if (instance.exports.render) {
          instance.exports.render();
        }
      }
      if (loading) loading.style.display = 'none';
    } catch (e) {
      console.error('WASM load error:', e);
      if (loading) loading.style.display = 'none';
      if (error) error.style.display = 'flex';
    }
  });
</script>

<style>
  .wasm-wrapper {
    position: relative;
    margin: 1.5rem 0;
  }

  .wasm-loading,
  .wasm-error {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem;
    border-radius: var(--hz-radius);
    font-size: 0.9rem;
  }

  .wasm-loading {
    color: var(--hz-text-muted);
    background: var(--hz-bg-secondary);
  }

  .wasm-error {
    color: var(--hz-error);
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  .spinner {
    width: 18px;
    height: 18px;
    border: 2px solid var(--hz-border);
    border-top-color: var(--hz-accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .wasm-container {
    background: var(--hz-bg-secondary);
    border: 1px solid var(--hz-border);
    border-radius: var(--hz-radius);
    overflow: hidden;
  }
</style>
